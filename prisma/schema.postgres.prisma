generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  LOAN
  CASH
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum ScheduleFrequency {
  ONCE
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

model PaySchedule {
  id                String            @id @default(cuid())
  name              String
  amount            Float
  frequency         ScheduleFrequency
  dayOfWeek         Int?
  dayOfMonth        Int?
  secondDayOfMonth  Int?
  customIntervalDays Int?
  startDate         DateTime
  endDate           DateTime?
  categoryId        String?
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId         String?
  account           Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  color             String            @default("#22c55e")
  icon              String            @default("briefcase")
  notes             String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model ScheduledExpense {
  id                String            @id @default(cuid())
  name              String
  amount            Float
  frequency         ScheduleFrequency
  dayOfWeek         Int?
  dayOfMonth        Int?
  secondDayOfMonth  Int?
  customIntervalDays Int?
  startDate         DateTime
  endDate           DateTime?
  categoryId        String?
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId         String?
  account           Account?          @relation(fields: [accountId], references: [id], onDelete: SetNull)
  color             String            @default("#f97316")
  icon              String            @default("calendar")
  notes             String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Account {
  id              String      @id @default(cuid())
  name            String
  type            AccountType
  institution     String?
  balance         Float       @default(0)
  color           String      @default("#6366f1")
  icon            String      @default("wallet")
  isArchived      Boolean     @default(false)
  isLinked        Boolean     @default(false)
  plaidAccountId  String?     @unique
  plaidItemId     String?
  plaidItem       PlaidItem?  @relation(fields: [plaidItemId], references: [id], onDelete: SetNull)
  mask            String?
  lastSyncedAt    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  transactions    Transaction[]
  goals           Goal[]
  paySchedules    PaySchedule[]
  scheduledExpenses ScheduledExpense[]
  envelopePoolFundings EnvelopePoolFunding[]
}

model PlaidItem {
  id                 String    @id @default(cuid())
  itemId             String    @unique
  accessToken        String
  institutionId      String?
  institutionName    String?
  transactionsCursor String?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  accounts           Account[]
}

model Category {
  id           String       @id @default(cuid())
  name         String
  type         CategoryType
  icon         String       @default("tag")
  color        String       @default("#8b5cf6")
  parentId     String?
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  budgetable   Boolean      @default(true)
  transactions Transaction[]
  budgets      Budget[]
  envelopes    Envelope[]
  paySchedules PaySchedule[]
  scheduledExpenses ScheduledExpense[]
}

model Transaction {
  id                 String    @id @default(cuid())
  accountId          String
  account            Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId         String?
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date               DateTime
  amount             Float
  description        String
  merchant           String?
  notes              String?
  isTransfer         Boolean   @default(false)
  plaidTransactionId String?   @unique
  createdAt          DateTime  @default(now())
}

model Budget {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount     Float
  month      DateTime

  @@unique([categoryId, month])
}

model Goal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  targetDate    DateTime?
  icon          String    @default("target")
  color         String    @default("#10b981")
  accountId     String?
  account       Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
}

model EnvelopePool {
  id         String   @id @default(cuid())
  month      DateTime @unique
  totalFunds Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Envelope {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month      DateTime
  allocated  Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, month])
}

model EnvelopePoolFunding {
  id        String   @id @default(cuid())
  month     DateTime
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  createdAt DateTime @default(now())
}

model EnvelopeTransfer {
  id             String   @id @default(cuid())
  month          DateTime
  amount         Float
  note           String?
  fromCategoryId String?
  toCategoryId   String?
  createdAt      DateTime @default(now())
}
